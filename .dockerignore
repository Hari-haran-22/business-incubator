# Dependencies (installed fresh in the image)
node_modules
server/node_modules

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Dev/test artifacts
*.log
npm-debug.log*
coverage/
.nyc_output/

# Git & CI metadata
.git
.gitignore
.github

# Editor config
.vscode
.idea
*.swp
*.swo

# Docker files themselves (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore

# OS cruft
.DS_Store
Thumbs.db
